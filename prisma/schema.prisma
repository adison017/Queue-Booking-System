generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now()) @map("created_at")
  
  stores   Store[]
  bookings Booking[]

  @@map("users")
}

model Store {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?   @db.Text
  ownerId     Int      @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  
  owner     User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  services  Service[]
  bookings  Booking[]
  schedules StoreSchedule[]

  @@map("stores")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(255)
  
  services     Service[]
  serviceLists ServiceList[]

  @@map("categories")
}

model ServiceList {
  id             Int     @id @default(autoincrement())
  categoryId     Int     @map("category_id")
  name           String  @db.VarChar(255)
  durationDays   Int     @default(0) @map("duration_days")
  durationMinutes Int    @default(30) @map("duration_minutes")
  price          Decimal @default(0) @db.Decimal(10, 2)
  
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("service_lists")
}

model Service {
  id             Int     @id @default(autoincrement())
  storeId        Int     @map("store_id")
  categoryId     Int?    @map("category_id")
  name           String  @db.VarChar(255)
  durationDays   Int     @default(0) @map("duration_days")
  durationMinutes Int    @default(30) @map("duration_minutes")
  price          Decimal @default(0) @db.Decimal(10, 2)
  
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@map("services")
}

model StoreSchedule {
  id        Int      @id @default(autoincrement())
  storeId   Int      @map("store_id")
  dayOfWeek Int      @map("day_of_week") // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  isClosed  Boolean  @default(false) @map("is_closed")
  
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  slots     ScheduleSlot[]

  @@unique([storeId, dayOfWeek])
  @@map("store_schedules")
}

model ScheduleSlot {
  id         Int           @id @default(autoincrement())
  scheduleId Int           @map("schedule_id")
  startTime  String        @map("start_time") // Format: "HH:mm"
  endTime    String        @map("end_time")   // Format: "HH:mm"
  
  schedule   StoreSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("schedule_slots")
}

model Booking {
  id        Int           @id @default(autoincrement())
  storeId   Int           @map("store_id")
  userId    Int           @map("user_id")
  serviceId Int           @map("service_id")
  bookingDate DateTime     @map("booking_date")
  startTime String @default("00:00") @map("start_time")
  endTime String @default("00:00") @map("end_time")
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now()) @map("created_at")
  
  store   Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("bookings")
}
